APP_IMAGE=ghcr.io/your-org/qcto-lmis-app:latest
APP_ENV=production
APP_BASE_URL=https://lmis.example.com
CORS_ORIGIN=https://lmis.example.com
RELEASE_VERSION=manual
RUN_DB_SETUP=true
TRUST_PROXY=true
JWT_SECRET=replace-with-a-long-random-secret
DATABASE_URL=
DB_SSL=no-verify
PGUSER=postgres
PGPASSWORD=change-me
PGDATABASE=qcto_lmis
REDIS_HOST=redis
REDIS_PORT=6379
